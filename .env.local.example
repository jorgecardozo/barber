# Supabase — copiá este archivo a .env.local y pegá los valores de tu proyecto.
# Cloud: Supabase → Project Settings → API.
# Local (supabase start): los imprime la CLI al arrancar (API URL + anon key + service_role).

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Solo se usa en el server (acciones admin / seed). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
